        <!-- Maven GPG Plugin & Maven Central Portal -->
        <maven-gpg-plugin.version>3.2.8</maven-gpg-plugin.version>
        <central.publishing.maven.version>0.10.0</central.publishing.maven.version>
    </properties>

    <!-- 开源协议 apache 2.0 -->
